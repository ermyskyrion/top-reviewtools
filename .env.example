# Chave de API da Brevo (Sendinblue) para envio de emails e gerenciamento de contatos.
# Obtenha em: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# ID da lista de contatos no Brevo onde os leads serão adicionados.
# Encontre em: Contatos > Listas > (selecione a lista) > ID exibido na URL ou no painel.
BREVO_LIST_ID=

# URL pública do site, usada na geração do sitemap e nas meta tags canônicas.
# Exemplo: https://top-reviewtools.com.br
NEXT_PUBLIC_SITE_URL=https://top-reviewtools.com.br

# Nome do site exibido em meta tags <title> e nas Open Graph tags (OG).
NEXT_PUBLIC_SITE_NAME=Top Review Tools
